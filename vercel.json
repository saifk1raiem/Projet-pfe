{
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://projet-pfe-production-d47f.up.railway.app/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://projet-pfe-production-d47f.up.railway.app/health"
    },
    {
      "source": "/docs",
      "destination": "https://projet-pfe-production-d47f.up.railway.app/docs"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://projet-pfe-production-d47f.up.railway.app/docs/:path*"
    },
    {
      "source": "/redoc",
      "destination": "https://projet-pfe-production-d47f.up.railway.app/redoc"
    },
    {
      "source": "/openapi.json",
      "destination": "https://projet-pfe-production-d47f.up.railway.app/openapi.json"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
